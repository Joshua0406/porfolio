{
  "outputDirectory": ".",
  "buildCommand": "echo done",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!assets|favicon\\.svg|robots\\.txt|sitemap\\.xml|about|brick|desertification|supermarket|kns|canvas|playground|uitvaart).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }]
    },
    {
      "source": "/uitvaart",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    },
    {
      "source": "/uitvaart/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    }
  ]
}
