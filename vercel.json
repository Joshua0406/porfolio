{
  "outputDirectory": ".",
  "buildCommand": "",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!assets|favicon\\.svg|robots\\.txt|sitemap\\.xml|about|brick|desertification|supermarket|kns|canvas|playground).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }]
    }
  ]
}
